 <office:body>
  <office:text text:use-soft-page-breaks="true">
   <text:sequence-decls>
    <text:sequence-decl text:display-outline-level="0" text:name="Illustration"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Table"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Text"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Drawing"/>
    <text:sequence-decl text:display-outline-level="0" text:name="Figure"/>
   </text:sequence-decls>
   <text:section text:style-name="Sect1" text:name="Section1">
    <text:section text:style-name="Sect2" text:name="Section2">
     <text:p text:style-name="P6">Xander Byrne</text:p>
     <text:p text:style-name="P59"><text:span text:style-name="T133">Calculated solut</text:span><text:span text:style-name="T134">ions to </text:span><text:span text:style-name="T135">modern</text:span><text:span text:style-name="T134"> </text:span><text:span text:style-name="T133">challenges </text:span><text:span text:style-name="T13">≫</text:span></text:p>
     <text:p text:style-name="P4"/>
     <text:p text:style-name="P1">Astrophysics PhD Student</text:p>
     <text:p text:style-name="P96"><text:span text:style-name="T2">University of Cambridge</text:span></text:p>
     <text:p text:style-name="P96"><text:span text:style-name="T17"><text:line-break/></text:span><text:span text:style-name="T15">xbyrne.github.io</text:span></text:p>
     <text:p text:style-name="P3">ajnb3@cam.ac.uk</text:p>
    </text:section>
    <text:p text:style-name="P15">Education</text:p>
    <text:p text:style-name="P5"/>
    <text:p text:style-name="P95">University of Cambridg<text:span text:style-name="T20">e<text:tab/>Cambridge, 2019-23</text:span></text:p>
    <text:p text:style-name="P92"><text:span text:style-name="T21">≫ </text:span><text:span text:style-name="T58">MSci Natural Sciences, </text:span><text:span text:style-name="T60">1st</text:span><text:span text:style-name="T58"> class with distinction</text:span></text:p>
    <text:p text:style-name="P91"><text:span text:style-name="T22">≫ </text:span><text:span text:style-name="T58">Ranked </text:span><text:span text:style-name="T131">top of the class </text:span><text:span text:style-name="T58">in Astrophysics examinations</text:span></text:p>
